# ── Web development ──────────────────────────────────────────────────────────
# (empty = relative URLs, proxied through Vite to localhost:8000)
VITE_API_BASE_URL=

# ── Native / production build ─────────────────────────────────────────────────
# Set this to your backend URL before running  npm run build:mobile
# Examples:
#   VITE_API_BASE_URL=http://192.168.1.42:8000   (same network)
#   VITE_API_BASE_URL=https://api.my-server.com  (deployed backend)
# VITE_API_BASE_URL=http://192.168.1.42:8000

# ── Capacitor live-reload (optional) ─────────────────────────────────────────
# Point the native app to your running Vite dev server for live reload.
# Run: CAP_DEV_SERVER=http://192.168.1.42:5173 npx cap sync
# CAP_DEV_SERVER=http://192.168.1.42:5173
