<?xml version="1.0" encoding="utf-8"?>
<!-- Wraps the foreground PNG with enough inset to stay within the adaptive-icon
     safe zone (centre 72dp of the 108dp canvas), so the full cherry is visible. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@mipmap/ic_launcher_foreground"
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp" />
</layer-list>
